FROM golang:1.20-alpine AS builder
RUN apk add --no-cache git ca-certificates build-base
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ARG TARGETOS
ARG TARGETARCH
RUN CGO_ENABLED=0 GOOS=${TARGETOS:-linux} GOARCH=${TARGETARCH:-amd64} go build -ldflags="-s -w" -o agent ./cmd/agent

FROM alpine:3.18
RUN apk add --no-cache ca-certificates docker-cli tzdata && update-ca-certificates
RUN addgroup -S app && adduser -S -G app -u 1000 app
WORKDIR /app
COPY --from=builder /app/agent /app/agent
RUN chown app:app /app/agent && chmod 0755 /app/agent
ENV AGENT_PORT=9000 GOMAXPROCS=2
USER app
EXPOSE 9000
ENTRYPOINT ["/app/agent"]
CMD []