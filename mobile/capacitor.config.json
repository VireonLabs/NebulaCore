{
  "appId": "com.nebulacore.app",
  "appName": "NebulaCore",
  "webDir": "../web/build",
  "bundledWebRuntime": false,
  "plugins": {
    "FingerprintAuth": {
      "disableBackup": true
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a1833",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "androidSplashResourceName": "splash",
      "iosLaunchStoryboard": "Splash"
    },
    "App": {
      "allowMixedContent": false
    },
    "SecureStorage": {}
  },
  "cordova": {},
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "url": null,
    "cleartext": false
  }
}